# Search provider override: exa, tavily, or firecrawl
# Leave unset to auto-select from any configured provider key.
# ResearchBuddy also auto-loads provider keys from ~/.hermes/.env and ~/.openclaw/openclaw.json.
SEARCH_PROVIDER=
SEARCH_NUM_RESULTS=20
SEARCH_MIN_RESULTS_PER_QUERY=10
SEARCH_QUERY_BUDGET=80
SEMANTIC_DEDUPE_ENABLED=true
SEMANTIC_EMBEDDING_MODEL_ID=Qwen/Qwen3-Embedding-0.6B
SEMANTIC_EMBEDDING_DEVICE=auto
SEMANTIC_EMBEDDING_MAX_LENGTH=512
SEMANTIC_EMBEDDING_BATCH_SIZE=16
SEMANTIC_QUERY_SIMILARITY_THRESHOLD=0.92
SEMANTIC_LANE_SIMILARITY_THRESHOLD=0.88
SEMANTIC_CARD_MMR_LAMBDA=0.72

# Exa
EXA_API_KEY=
EXA_SEARCH_TYPE=auto
EXA_USER_LOCATION=US

# Tavily
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
TAVILY_TOPIC=general
TAVILY_AUTO_PARAMETERS=false

# Firecrawl
FIRECRAWL_API_KEY=
FIRECRAWL_COUNTRY=US
FIRECRAWL_LOCATION=United States

# Optional integrations
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
